<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <p><%= project.description %></p>

        <h2>Categories</h2>
        <ul>
            <% categories.forEach(category => { %>
                <li>
                    <a href="/category/<%= category.id %>"><%= category.name %></a>
                </li>
            <% }) %>
        </ul>
    </main>
<%- include('partials/footer') %>
