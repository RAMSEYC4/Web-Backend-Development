<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <h2>Service Projects in <%= category.name %></h2>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.id %>"><%= project.name %></a>
                </li>
            <% }) %>
        </ul>
        <p><a href="/edit-category/<%= category.id %>">Edit Category</a></p>
    </main>
<%- include('partials/footer') %>
