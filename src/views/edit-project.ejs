<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/edit-project/<%= projectDetails.id %>" method="POST">
    <div class="form-group">
      <label for="name">Project Name</label>
      <input
        type="text"
        id="name"
        name="name"
        value="<%= projectDetails.name %>"
        maxlength="150"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        maxlength="500"
        required
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="eventDate">Date</label>
      <input
        type="date"
        id="eventDate"
        name="eventDate"
        value="<%= new Date(projectDetails.event_date).toISOString().split('T')[0] %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select
        id="organizationId"
        name="organizationId"
        required
      >
        <option value="">Select an organization</option>
        <% organizations.forEach(org => { %>
          <option
            value="<%= org.id %>"
            <%= org.id === projectDetails.organization_id ? 'selected' : '' %>
          ><%= org.name %></option>
        <% }); %>
      </select>
    </div>

    <button type="submit">Update Project</button>
  </form>
</main>
<%- include('partials/footer') %>
